# Supabase (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never expose to the browser or commit real values
SUPABASE_SERVICE_ROLE_KEY=

# Optional: canonical site URL for OAuth redirect hints (defaults to window origin in the browser)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Vendor Google OAuth: enable Google in Supabase → Authentication → Providers, then add Redirect URL:
#   {NEXT_PUBLIC_SITE_URL or http://localhost:3000}/auth/oauth-callback
#   (Legacy /api/auth/callback redirects to the page above.)
# Authentication → Email: disable "Confirm email" for instant vendor signup (recommended for this app).

# Legacy customer login / SQLite (optional if still used)
# EVENTEASE_LOGIN_EMAIL=
# EVENTEASE_LOGIN_PASSWORD=
# EVENTEASE_VENDOR_SESSION_SECRET=

# WhatsApp Cloud API (Meta) — server-side template messages only (see pages/api/whatsapp/*)
# Required for vendor profile WhatsApp OTP: long-lived token + Phone Number ID (digits only, no +).
# Never commit real tokens; use .env.local only.
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
#
# Wishlist WhatsApp templates — create & approve in Meta WhatsApp Manager (name + locale must match exactly).
# Project callback template (English): eventizo_callback_request + locale en
# WHATSAPP_TEMPLATE_CALLBACK=eventizo_callback_request
# WHATSAPP_TEMPLATE_CALLBACK_LANG=en
# WHATSAPP_TEMPLATE_AVAILABILITY=availability_request → BODY: 3 vars — (1) event date (2) summary (3) customer name
# If availability uses a different locale: WHATSAPP_TEMPLATE_AVAILABILITY_LANG=en_US
# If Meta returns #132001: set name + WHATSAPP_TEMPLATE_CALLBACK_LANG to match Manager exactly (e.g. en_US).
#
# POST /api/callback/request — Meta template "New Customer Callback Request" style, 3 BODY variables:
# (1) event date (formatted, or "Not specified") (2) preferred callback time slot (3) message (includes "Call on {date}").
# Header, footer, and quick-reply button (e.g. Accept Request) are defined in WhatsApp Manager, not in app code.
# Require wedding event date in Schedule Callback: set BOTH to 1
# CALLBACK_EVENT_DATE_REQUIRED=1
# NEXT_PUBLIC_CALLBACK_EVENT_DATE_REQUIRED=1
#
# Template with exactly ONE body variable = 6-digit OTP (name + language must match WhatsApp Manager; #132001 if not)
# WHATSAPP_TEMPLATE_VENDOR_OTP=eventizo_wa_auth
# WHATSAPP_TEMPLATE_LANG=en
# Optional: override locale for vendor OTP only if #132001 (e.g. en_US, hi)
# WHATSAPP_TEMPLATE_VENDOR_OTP_LANG=
# WHATSAPP_GRAPH_VERSION=v19.0
#
# Vendor WhatsApp OTP: run supabase/migrations/014_vendor_whatsapp_otp_challenges.sql and 015_vendor_whatsapp_otp_destination.sql
#
# Vendor profile save session (HMAC) after WhatsApp OTP verify — required in production
# VENDOR_OTP_SESSION_SECRET=
# Optional fallback if VENDOR_OTP_SESSION_SECRET unset (prefer setting VENDOR_OTP_SESSION_SECRET)
# CALLBACK_OTP_SECRET=
# Optional: HMAC pepper for stored OTP hash (defaults to VENDOR_OTP_SESSION_SECRET or dev placeholder)
# OTP_CODE_PEPPER=
# VENDOR_OTP_SESSION_TTL_SEC=1800
# Set to 0 to skip WhatsApp session check on PATCH /api/vendor/update (local dev only)
# VENDOR_OTP_ENFORCE=1
# NEXT_PUBLIC_VENDOR_OTP_ENFORCE=1

# Weaviate (Vector DB) — server-side
# WEAVIATE_URL=https://your-cluster.weaviate.network
# WEAVIATE_API_KEY=
# WEAVIATE_CLASS_VENDOR_IMAGE=VendorImage
# AI_SEARCH_ENABLED=true
# EMBEDDING_PROVIDER=hash-v1
# GEMINI_API_KEY=
# GEMINI_LLM_MODEL=gemini-2.0-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# GEMINI_EMBEDDING_DIMENSIONS=256
# GEMINI_LLM_ENABLED=false
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=

# Firebase Phone OTP (optional vendor verification)
# Client (safe to expose in browser)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Optional dev-only switch (use with Firebase Auth test phone numbers)
# NEXT_PUBLIC_FIREBASE_OTP_TEST_MODE=false
#
# Server (private)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Customer login (phone OTP) — Firebase Phone Auth (browser) + Firebase Admin verify + SQLite customers
# (same EVENTEASE_DB_FILE as vendors). SMS is sent by Firebase, not Twilio.
# Requires the same NEXT_PUBLIC_FIREBASE_* + FIREBASE_* admin vars as below, Phone Auth enabled in
# Firebase Console, and authorized domains (e.g. localhost, your ngrok host).
# Optional dev: NEXT_PUBLIC_FIREBASE_OTP_TEST_MODE=true (see Firebase test phone numbers)
# Customer browser session (signed cookie, default 30 days). Prefer AUTH_SESSION_SECRET.
# AUTH_SESSION_SECRET=
# CUSTOMER_SESSION_SECRET=
# Optional: session length in days (1–365, default 30)
# CUSTOMER_SESSION_MAX_AGE_DAYS=30
# Optional pepper for stored OTP hash
# CUSTOMER_OTP_PEPPER=
